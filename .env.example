# 公开展示在浏览器中的品牌名（水印与标题旁展示）
NEXT_PUBLIC_BRAND_NAME=你的品牌

# 可选：模拟云端耗时（毫秒），便于体验加载态；生产请置 0 或删除
TRY_ON_MOCK_DELAY_MS=0

# 设为 1 或 true 时强制走本地 Mock（回显人物图），不调用方舟 API
# TRY_ON_USE_MOCK=0

# 火山方舟图片生成 API（服务端-only，勿使用 NEXT_PUBLIC_）
# ARK_API_KEY=
# ARK_IMAGE_API_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
# ARK_IMAGE_MODEL=doubao-seedream-5-0-260128
# ARK_TIMEOUT_MS=120000
