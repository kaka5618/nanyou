# 复制为 .env.local 后填写，勿提交真实密钥

# ---------- 对话 LLM（火山方舟 OpenAI 兼容，默认）----------
# 必填：方舟 API Key（仅服务端读取）
ARK_API_KEY=
# 可选：默认 https://ark.cn-beijing.volces.com/api/v3
# ARK_BASE_URL=
# 可选：默认 doubao-1-5-pro-32k-250115
# ARK_CHAT_MODEL=
# 可选：毫秒，默认 28000
# ARK_TIMEOUT_MS=

# 对话提供商：ark | coze，默认 ark
# LLM_PROVIDER=ark

# Ark 失败时是否回退 Coze SDK（需 Coze 运行环境仍可用）
# LLM_FALLBACK_COZE=false

# ----------仍使用 Coze SDK 时（TTS / 生图 / LLM=coze）----------
# COZE_LLM_MODEL=doubao-seed-1-8-251228
